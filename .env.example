# ============================================================
#  ShopHub environment variables
# ============================================================

# ---- Database (Supabase PostgreSQL) ----
# From Supabase: Project → Settings → Database → Connection string.
# DATABASE_URL = "Transaction pooler" (host has ...pooler..., port 6543)
# DIRECT_URL   = "Direct connection"  (port 5432) — used by prisma migrate/db push
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---- NextAuth ----
# In production set NEXTAUTH_URL to your deployed URL (e.g. https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-key-min-32-chars"

# ---- App URL ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Stripe (optional — demo checkout works without it) ----
STRIPE_SECRET_KEY=""

# ---- Email alerts (OPTIONAL — leave blank to run without email) ----
RESEND_API_KEY=""
EMAIL_FROM="ShopHub <onboarding@resend.dev>"
ALERT_EMAIL=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
